{
  "name": "api-key-validator",
  "version": "1.0.0",
  "description": "API Key 批量验证管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.indims.api-key-validator",
    "productName": "API Key 管理器",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "package.json",
      "../app.py",
      "../api_validator.py",
      "../requirements.txt"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["*.py", "*.txt"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
